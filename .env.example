INFLUXDB_TOKEN=
# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_ORG=aerobatics
# INFLUXDB_BUCKET=drone_diagnostics

# Storage management
# InfluxDB 2.x OSS has no hard byte-size disk cap; retention period is the
# official mechanism — data older than this is deleted automatically.
# Target ~1 GB: at ~2 Hz / small payloads the diagnostic data grows slowly;
# 90d keeps well under 1 GB. Lower to 30d for tighter bounds, raise to 0
# (infinite) only if you manage storage externally.
# Format: duration string, e.g. 1h, 30d, 8760h (= 1 year). 0 = infinite.
INFLUXDB_RETENTION=90d

# In-memory write-cache cap (bytes). InfluxDB buffers incoming writes here
# before flushing to disk. 256 MB gives headroom during bulk ULG ingestion
# while staying well under typical host RAM. Raise to 512 MB (536870912)
# if you see write-stall warnings under heavy load.
INFLUXDB_CACHE_MAX_MEMORY_SIZE=268435456
